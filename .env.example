# Copie este arquivo para .env.local e preencha com suas credenciais
# Obtenha em: https://supabase.com/dashboard/project/<project-id>/settings/api

VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Opcional — monitoramento de erros em produção (Sentry). Deixe vazio para
# desativar; sem DSN o app funciona normalmente e o Sentry não é inicializado.
# Obtenha em: https://sentry.io (Settings → Projects → <projeto> → Client Keys)
VITE_SENTRY_DSN=
