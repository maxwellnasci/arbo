{
  "mcpServers": {
    "deepseek": {
      "command": "npx",
      "args": [
        "-y",
        "deepseek-mcp-server@0.3.1"
      ],
      "env": {
        "DEEPSEEK_API_KEY": "YOUR_API_KEY_HERE",
        "DEEPSEEK_DEFAULT_MODEL": "deepseek-v4-pro",
        "DEEPSEEK_BASE_URL": "https://api.deepseek.com"
      }
    }
  }
}
